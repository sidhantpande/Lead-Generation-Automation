# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Resend Email Configuration
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=reports@yourdomain.com
RESEND_FROM_NAME=SimplifIQ Intelligence

# Google API Configurations (Service Account)
# Make sure the service_account.json is placed in the credentials/ folder
GOOGLE_SERVICE_ACCOUNT_PATH=credentials/service_account.json
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Local Server Settings
APP_HOST=0.0.0.0
APP_PORT=8000
OUTPUT_DIR=outputs
