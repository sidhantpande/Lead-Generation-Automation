# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail SMTP Email Configuration
GMAIL_ADDRESS=your_gmail_address_here@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx   # 16-character app password

# Google API Configurations (Service Account)
# Make sure the service_account.json is placed in the credentials/ folder
GOOGLE_SERVICE_ACCOUNT_PATH=credentials/service_account.json
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Local Server Settings
APP_HOST=0.0.0.0
APP_PORT=8000
OUTPUT_DIR=outputs
